# ──────────────────────────────────────────────────────────────────
# Copia aquest fitxer com .env.local i afegeix la teva clau d'API.
# Aquest fitxer NO s'ha de pujar mai a Git (ja està al .gitignore).
# ──────────────────────────────────────────────────────────────────

# Obtén la teva clau a: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: limita les peticions per IP (deixa buit per desactivar)
# RATE_LIMIT_PER_MINUTE=20
